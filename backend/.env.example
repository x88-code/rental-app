PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/rental_house_management
MONGO_URI_DIRECT=mongodb://username:password@host1:27017,host2:27017,host3:27017/?authSource=admin&replicaSet=your-replica-set&retryWrites=true&w=majority&tls=true&serverSelectionTimeoutMS=10000&connectTimeoutMS=10000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:8081
